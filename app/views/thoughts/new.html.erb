<div class="mb-6">
  <%= link_to "← Back to #{@message.conversation.title}", conversation_path(@message.conversation),
      class: "text-sm text-blue-600 hover:text-blue-800 no-underline" %>
</div>

<h1 class="text-2xl font-bold text-gray-900 mb-2">New Thought</h1>
<p class="text-sm text-gray-500 mb-6">For message: "<%= truncate(@message.text, length: 80) %>"</p>

<div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
  <%= render "shared/form_errors", record: @thought %>

  <%= form_with(model: [@message, @thought], class: "space-y-4") do |f| %>
    <div>
      <%= f.label :text, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :text, rows: 4,
          class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div>
      <%= f.label :date_time_sent, "Date/time sent", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.datetime_local_field :date_time_sent,
          class: "border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div>
      <%= f.submit "Create Thought",
          class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 text-sm cursor-pointer" %>
    </div>
  <% end %>
</div>
