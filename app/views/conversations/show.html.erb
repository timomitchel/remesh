<div class="mb-6">
  <%= link_to "← Back to Conversations", conversations_path,
      class: "inline-block bg-blue-600 text-white px-3 py-1.5 rounded hover:bg-blue-700 text-sm no-underline" %>
</div>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900"><%= @conversation.title %></h1>
  <p class="text-sm text-gray-500 mt-1">Started: <%= @conversation.start_date.strftime("%B %d, %Y") %></p>
</div>

<div class="mb-6 flex items-center justify-between">
  <h2 class="text-lg font-semibold text-gray-800">Messages</h2>
  <%= link_to "Add Message", new_conversation_message_path(@conversation),
      class: "bg-blue-600 text-white px-3 py-1.5 rounded hover:bg-blue-700 text-sm no-underline" %>
</div>

<% if @messages.any? %>
  <div class="space-y-4">
    <% @messages.each do |message| %>
      <div id="message-<%= message.id %>" class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
        <div class="flex items-start justify-between">
          <p class="text-gray-800"><%= message.text %></p>
          <span class="text-xs text-gray-400 whitespace-nowrap ml-4">
            <%= message.date_time_sent.strftime("%b %d, %Y %I:%M %p") %>
          </span>
        </div>

        <div class="mt-3 pl-4 border-l-2 border-gray-200">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-medium text-gray-600">Thoughts (<%= message.thoughts.size %>)</span>
            <%= link_to "Add Thought", new_message_thought_path(message),
                class: "bg-blue-600 text-white px-3 py-1.5 rounded hover:bg-blue-700 text-sm no-underline" %>
          </div>

          <% if message.thoughts.any? %>
            <div class="space-y-2">
              <% message.thoughts.each do |thought| %>
                <div class="bg-gray-50 rounded p-2">
                  <p class="text-sm text-gray-700"><%= thought.text %></p>
                  <span class="text-xs text-gray-400">
                    <%= thought.date_time_sent.strftime("%b %d, %Y %I:%M %p") %>
                  </span>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-gray-400">No thoughts yet.</p>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="text-gray-500 text-center py-8">No messages yet. Add one to get started.</p>
<% end %>
