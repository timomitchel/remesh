<div class="mb-6">
  <%= link_to "← Back to Conversations", conversations_path,
      class: "text-sm text-blue-600 hover:text-blue-800 no-underline" %>
</div>

<h1 class="text-2xl font-bold text-gray-900 mb-6">New Conversation</h1>

<div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
  <%= render "shared/form_errors", record: @conversation %>

  <%= form_with(model: @conversation, class: "space-y-4") do |f| %>
    <div>
      <%= f.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :title,
          class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div>
      <%= f.label :start_date, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.date_field :start_date,
          class: "border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div>
      <%= f.submit "Create Conversation",
          class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 text-sm cursor-pointer" %>
    </div>
  <% end %>
</div>
